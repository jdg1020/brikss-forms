# ═══════════════════════════════════════════════════
# BRIKSS Forms - Variables de Entorno
# Copia este archivo como .env y configura los valores
# ═══════════════════════════════════════════════════

# Puerto del servidor
PORT=3000

# ── Google Service Account (para Sheets) ────────────
# Ruta al archivo JSON de la cuenta de servicio
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# ── Google OAuth2 (para Drive) ──────────────────────
# Crear en: Google Cloud Console > APIs > Credenciales > OAuth 2.0
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback
GOOGLE_REFRESH_TOKEN=tu_refresh_token_aqui

# ── Google Drive ────────────────────────────────────
# ID de la carpeta raiz "BRIKSS Forms" en Google Drive
GOOGLE_DRIVE_FOLDER_ID=id_carpeta_brikss_forms

# ── Google Sheets ───────────────────────────────────
# ID del Google Sheet centralizado para registro de formularios
GOOGLE_SHEET_ID=id_spreadsheet_aqui

# ── Email (Nodemailer con Gmail) ──────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=notifications@brikss.com
EMAIL_PASSWORD=tu_app_password_aqui
EMAIL_FROM="BRIKSS Inmobiliaria" <notifications@brikss.com>

# ── URLs ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Entorno ───────────────────────────────────────
NODE_ENV=development
