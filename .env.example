# ═══════════════════════════════════════════════════
# BRIKSS Forms - Variables de Entorno
# Copia este archivo como .env y configura los valores
# ═══════════════════════════════════════════════════

# Puerto del servidor
PORT=3000

# Entorno (development | production)
NODE_ENV=development

# ── Google Service Account ───────────────────────────
# Una sola Service Account se usa tanto para Drive como para Sheets.
# La carpeta GOOGLE_DRIVE_FOLDER_ID y el spreadsheet GOOGLE_SHEET_ID deben estar
# compartidos con el email de la Service Account como Editor.
#
# En desarrollo (archivo JSON local):
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json
#
# En produccion (Render): pegar el contenido del JSON como una sola linea aqui.
# Si esta seteada, tiene prioridad sobre _KEY_FILE.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ── Google Drive ─────────────────────────────────────
# ID de la carpeta raiz "BRIKSS Forms" donde se crean los expedientes.
GOOGLE_DRIVE_FOLDER_ID=id_carpeta_brikss_forms

# ── Google Sheets ────────────────────────────────────
# ID del Google Sheet centralizado para registro de formularios.
GOOGLE_SHEET_ID=id_spreadsheet_aqui

# ── Email (Nodemailer con Gmail) ─────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=notifications@brikss.com
EMAIL_PASSWORD=tu_app_password_aqui
EMAIL_FROM="BRIKSS Inmobiliaria" <notifications@brikss.com>

# ── URLs ─────────────────────────────────────────────
# Origenes permitidos por CORS (separados por coma en produccion).
FRONTEND_URL=http://localhost:3000
